<%
const title = '结算';
const page  = 'settlement';
const body = `
<div class="page-header">
  <h2>月度结算</h2>
</div>

<div class="card form-card">
  <h3>运行结算</h3>
  <div class="form-grid">
    <div class="form-row">
      <label>团队</label>
      <select id="sTeam" onchange="onTeamMonthChange()"></select>
    </div>
    <div class="form-row">
      <label>月份</label>
      <input type="month" id="sMonth" onchange="onTeamMonthChange()">
    </div>
  </div>
  <div id="teamFormulaBox" style="display:none;margin:8px 0 12px;padding:10px 14px;background:#f0f4ff;border-radius:8px;font-size:13px;color:#444;line-height:1.7"></div>

  <!-- 成员收入预览 -->
  <div id="memberPreviewSection" style="display:none;margin-bottom:14px">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px">
      <div style="font-size:14px;font-weight:600;color:#333">团队成员本月上报收入</div>
      <a id="goRecordsBtn" href="/admin/records" style="font-size:13px;color:#6c63ff;text-decoration:none;padding:4px 10px;border:1px solid #6c63ff;border-radius:6px">前往录入页手动编辑</a>
    </div>
    <div class="table-wrap" style="margin-bottom:0">
      <table class="data-table">
        <thead><tr><th>成员</th><th>京粉收入</th><th>淘宝收入</th><th>支出</th><th>净收入</th><th>状态</th></tr></thead>
        <tbody id="memberPreviewBody"></tbody>
      </table>
    </div>
  </div>

  <div class="form-actions">
    <button class="btn btn-primary" onclick="runSettle()">🧮 运行结算</button>
    <button class="btn" onclick="loadSettlements()">📋 查看历史结算</button>
  </div>
  <div id="settleErr" class="error-msg" style="display:none"></div>
</div>

<div id="settleResult" style="display:none" class="card">
  <div class="settle-header">
    <div>
      <h3 id="settleTitle"></h3>
      <div id="settleCompare" class="compare-bar"></div>
    </div>
    <div class="settle-actions">
      <button class="btn btn-primary" id="btnPush" onclick="pushSettle()">📨 推送微信</button>
      <button class="btn" id="btnFeishu" onclick="feishuSync()">🔄 同步飞书</button>
    </div>
  </div>
  <div class="stats-grid" id="settleSummary"></div>
  <h4 style="margin:.75rem 0 .5rem">成员分成明细</h4>
  <div class="table-wrap">
    <table class="data-table">
      <thead><tr><th>姓名</th><th>应收</th><th>实收</th><th>差额（正=待收，负=待付）</th></tr></thead>
      <tbody id="settleMemberBody"></tbody>
    </table>
  </div>
  <h4 style="margin:.75rem 0 .5rem">最优转账方案</h4>
  <div id="settleTransfers" class="transfers-list"></div>

  <h4 style="margin:1.25rem 0 .5rem">结算推送文案</h4>
  <div style="position:relative">
    <textarea id="settlePushText" readonly style="width:100%;height:240px;font-family:monospace;font-size:13px;padding:12px 12px 12px 14px;border:1px solid #e0e0e0;border-radius:8px;background:#fafafa;resize:vertical;box-sizing:border-box;line-height:1.8;color:#333"></textarea>
    <button onclick="copyPushText(this)" style="position:absolute;top:10px;right:10px;padding:5px 14px;background:#6c63ff;color:#fff;border:none;border-radius:6px;cursor:pointer;font-size:12px;font-weight:600">复制</button>
  </div>
</div>

<h3 style="margin:1.5rem 0 .5rem">历史结算记录</h3>
<div class="table-wrap">
  <table class="data-table">
    <thead><tr><th>月份</th><th>团队</th><th>总收入</th><th>总支出</th><th>去年同月</th><th>前年同月</th><th>前前年同月</th><th>推送</th><th>操作</th></tr></thead>
    <tbody id="settleListBody"><tr><td colspan="9">加载中...</td></tr></tbody>
  </table>
</div>
`;
const pageScript = `<script>
let teamsMap = {}, allTeams = [], currentSettlement = null;

async function initPage() {
  const tr = await api('/api/teams');
  allTeams = tr ? tr.data || [] : [];
  teamsMap = Object.fromEntries(allTeams.map(t => [t.id, t.name]));
  document.getElementById('sTeam').innerHTML = allTeams.map(t =>
    '<option value="'+t.id+'">'+t.name+'</option>').join('');
  document.getElementById('sMonth').value = new Date().toISOString().slice(0,7);
  onTeamMonthChange();
  loadSettlements();
}

function showTeamFormula() {
  var teamId = parseInt(document.getElementById('sTeam').value);
  var team = allTeams.find(function(t){ return t.id === teamId; });
  var box = document.getElementById('teamFormulaBox');
  if (!team) { box.style.display = 'none'; return; }
  var rm = team.rule_members || [];
  var html = '<strong>分成规则：</strong>';
  if (rm.length > 0) {
    html += rm.map(function(m) {
      var rule = m.rule_mode === 'formula'
        ? '<code style="background:#e8ecff;padding:1px 5px;border-radius:3px">' + m.formula + '</code>'
        : '<strong>' + (m.ratio != null ? (m.ratio * 100).toFixed(0) : '?') + '%</strong>';
      return '<strong>' + m.member_name + '</strong> → ' + rule;
    }).join('　　');
  } else {
    html += '<span style="color:#f44336">⚠️ 未配置成员分账公式，请先到团队管理页面设置</span>';
  }
  box.innerHTML = html;
  box.style.display = 'block';
}

async function loadMemberPreview() {
  var teamId = document.getElementById('sTeam').value;
  var month  = document.getElementById('sMonth').value;
  var sec = document.getElementById('memberPreviewSection');
  if (!teamId || !month) { sec.style.display = 'none'; return; }
  sec.style.display = 'block';

  var goBtn = document.getElementById('goRecordsBtn');
  if (goBtn) goBtn.href = '/admin/records';

  var [ur, rr] = await Promise.all([
    api('/api/users?team_id=' + teamId),
    api('/api/records?team_id=' + teamId + '&month=' + month),
  ]);
  var members = ur ? ur.data || [] : [];
  var records = rr ? rr.data || [] : [];

  // 聚合每位成员的 income_records 数据
  var memberNames = members.map(function(u){ return u.name; }).filter(Boolean);
  // 也把 records 里出现但不在成员列表里的人名加进来
  records.forEach(function(r){
    if (r.person_name && memberNames.indexOf(r.person_name) === -1) memberNames.push(r.person_name);
  });

  document.getElementById('memberPreviewBody').innerHTML = memberNames.map(function(name) {
    var recs = records.filter(function(r){ return r.person_name === name; });
    var incomeRecs = recs.filter(function(r){ return r.item_type === 'income'; });
    var expRecs    = recs.filter(function(r){ return r.item_type === 'expense'; });
    var taxRecs    = recs.filter(function(r){ return r.item_type === 'tax'; });
    var adjRecs    = recs.filter(function(r){ return r.item_type === 'adjust'; });

    var jingfen = incomeRecs.filter(function(r){ return r.item_name && r.item_name.indexOf('京粉') !== -1; })
                            .reduce(function(s,r){ return s + r.amount; }, 0);
    var taobao  = incomeRecs.filter(function(r){ return r.item_name && r.item_name.indexOf('淘宝') !== -1; })
                            .reduce(function(s,r){ return s + r.amount; }, 0);
    var expTotal = expRecs.reduce(function(s,r){ return s + Math.abs(r.amount); }, 0);
    var incTotal = incomeRecs.reduce(function(s,r){ return s + r.amount; }, 0);
    var taxTotal = taxRecs.reduce(function(s,r){ return s + r.amount; }, 0);
    var adjTotal = adjRecs.reduce(function(s,r){ return s + r.amount; }, 0);
    var net = incTotal - taxTotal - expTotal + adjTotal;
    var hasData = recs.length > 0;

    function fmt(v) { return parseFloat(v).toFixed(2); }
    return '<tr>' +
      '<td><strong>' + name + '</strong></td>' +
      '<td>' + (jingfen  ? '<span style="color:#6c63ff">¥' + fmt(jingfen) + '</span>'  : '<span style="color:#bbb">-</span>') + '</td>' +
      '<td>' + (taobao   ? '<span style="color:#6c63ff">¥' + fmt(taobao)  + '</span>'  : '<span style="color:#bbb">-</span>') + '</td>' +
      '<td>' + (expTotal ? '<span style="color:#f44336">-¥' + fmt(expTotal) + '</span>' : '<span style="color:#bbb">-</span>') + '</td>' +
      '<td><strong>' + (hasData ? '¥' + fmt(net) : '-') + '</strong></td>' +
      '<td>' + (hasData ? '<span style="color:#4caf50">✅已录入</span>' : '<span style="color:#f44336">⚠️未录入</span>') + '</td>' +
      '</tr>';
  }).join('') || '<tr><td colspan="6" style="color:#999">该团队暂无成员或记录</td></tr>';
}

function onTeamMonthChange() {
  showTeamFormula();
  loadMemberPreview();
}

async function runSettle() {
  const teamId = document.getElementById('sTeam').value;
  const month  = document.getElementById('sMonth').value;
  if (!teamId || !month) return alert('请选择团队和月份');
  const res = await api('/api/settlements/run', { method:'POST', body: JSON.stringify({team_id:Number(teamId),month}) });
  if (res && res.ok) { showSettleResult(res.data); loadSettlements(); loadMemberPreview(); }
  else { var e = document.getElementById('settleErr'); e.textContent = (res&&res.message)||'结算失败'; e.style.display='block'; }
}

function showSettleResult(s) {
  currentSettlement = s;
  document.getElementById('settleResult').style.display = 'block';
  document.getElementById('settleErr').style.display = 'none';
  document.getElementById('btnPush').dataset.id = s.id;
  document.getElementById('btnFeishu').dataset.team = s.team_id;
  document.getElementById('btnFeishu').dataset.month = s.month;
  const r = s.result_json || {};
  document.getElementById('settleTitle').textContent = (teamsMap[s.team_id]||s.team_id) + ' · ' + s.month + ' 结算结果';
  var _curIncome = parseFloat(r.total_income || 0);
  var _pct = function(ref) {
    if (!ref || ref <= 0) return '';
    var p = ((_curIncome - ref) / ref * 100).toFixed(1);
    return '（' + (p >= 0 ? '+' : '') + p + '%）';
  };
  document.getElementById('settleCompare').innerHTML = [
    s.year_compare_last  != null ? '去年同月: ¥'+(s.year_compare_last/100).toFixed(2)+_pct(s.year_compare_last/100) : '',
    s.year_compare_prev2 != null ? '前年同月: ¥'+(s.year_compare_prev2/100).toFixed(2)+_pct(s.year_compare_prev2/100) : '',
    s.year_compare_prev3 != null ? '前前年同月: ¥'+(s.year_compare_prev3/100).toFixed(2)+_pct(s.year_compare_prev3/100) : '',
  ].filter(Boolean).join('　｜　');
  document.getElementById('settleSummary').innerHTML = [
    {label:'总收入', value:'¥'+(r.total_income||0)},
    {label:'总支出', value:'¥'+(r.total_expense||0)},
    {label:'退税',   value:'¥'+(r.total_tax||0)},
    {label:'可分配', value:'¥'+(r.distributable||0)},
  ].map(function(item){return '<div class="stat-card"><div class="stat-label">'+item.label+'</div><div class="stat-value">'+item.value+'</div></div>';}).join('');
  var mc = r.member_compare || {};
  var mcParts = s.month.split('-');
  var mcYr = Number(mcParts[0]), mcMn = mcParts[1];
  var mcFmt = function(cents) { return cents != null && cents > 0 ? '¥'+(cents/100).toFixed(2) : null; };
  var mcPct = function(cur, ref) {
    if (!ref || ref <= 0) return '';
    var p = ((cur - ref) / ref * 100).toFixed(1);
    return (p >= 0 ? '+' : '') + p + '%';
  };
  document.getElementById('settleMemberBody').innerHTML = (r.members||[]).map(function(m) {
    var diff = parseFloat(m.diff);
    var cls = diff > 0 ? 'text-green' : diff < 0 ? 'text-red' : '';
    var arrow = diff > 0 ? '↑待收' : diff < 0 ? '↓待付' : '✅平衡';
    var curCents = Math.round(parseFloat(m.actual) * 100);
    var v1 = mc.last  && mc.last[m.name]  != null ? mc.last[m.name]  : null;
    var v2 = mc.prev2 && mc.prev2[m.name] != null ? mc.prev2[m.name] : null;
    var v3 = mc.prev3 && mc.prev3[m.name] != null ? mc.prev3[m.name] : null;
    var cmpParts = [];
    if (v1 != null) cmpParts.push((mcYr-1)+'-'+mcMn+'：'+mcFmt(v1)+'（'+mcPct(curCents,v1)+'）');
    if (v2 != null) cmpParts.push((mcYr-2)+'-'+mcMn+'：'+mcFmt(v2)+'（'+mcPct(curCents,v2)+'）');
    if (v3 != null) cmpParts.push((mcYr-3)+'-'+mcMn+'：'+mcFmt(v3)+'（'+mcPct(curCents,v3)+'）');
    var cmpRow = cmpParts.length
      ? '<tr><td colspan="4" style="font-size:12px;color:#888;padding:2px 12px 8px;background:#fafafa">历史同月收入：' + cmpParts.join('　') + '</td></tr>'
      : '';
    return '<tr><td><strong>'+m.name+'</strong></td><td>¥'+m.should_get+'</td><td>¥'+m.actual+'</td>' +
      '<td class="'+cls+'">¥'+m.diff+' <small>'+arrow+'</small></td></tr>' + cmpRow;
  }).join('') || '<tr><td colspan="4">-</td></tr>';
  document.getElementById('settleTransfers').innerHTML = (r.transfers||[]).length
    ? (r.transfers||[]).map(function(t){
        return '<div style="padding:8px 12px;background:#fff8e1;border-radius:8px;margin-bottom:6px">💸 <strong>'+t.from+'</strong> 转给 <strong>'+t.to+'</strong>：<span style="color:#6c63ff;font-weight:700">¥'+t.amount+'</span></div>';
      }).join('')
    : '<div class="text-muted" style="padding:8px">无需转账（已完全平衡）</div>';
  document.getElementById('settlePushText').value = generatePushText(s);
  document.getElementById('settleResult').scrollIntoView({ behavior:'smooth' });
}

function generatePushText(s) {
  var r = s.result_json || {};
  var teamName = teamsMap[s.team_id] || s.team_id;
  var team = allTeams.find(function(t){ return t.id === s.team_id; });
  var sep = '━━━━━━━━━━━━━━━━━━━━';
  var lines = [];
  var fmt = function(v) { return parseFloat(v || 0).toFixed(2); };

  lines.push('【月度结算报告】' + teamName + ' · ' + s.month);
  lines.push(sep);

  // 收支概览
  lines.push('💰 收支概览');
  lines.push('总收入：¥' + fmt(r.total_income));
  if (parseFloat(r.total_expense || 0) > 0) lines.push('总支出：¥' + fmt(r.total_expense));
  if (parseFloat(r.total_tax    || 0) > 0) lines.push('退　税：¥' + fmt(r.total_tax));
  lines.push('可分配：¥' + fmt(r.distributable));

  // 同比
  if (s.year_compare_last != null || s.year_compare_prev2 != null || s.year_compare_prev3 != null) {
    lines.push(sep);
    lines.push('📊 同比对比');
    var parts = s.month.split('-');
    var yr = parts[0], mn = parts[1];
    var curVal = parseFloat(r.total_income || 0);
    var pctStr = function(refVal) {
      return refVal > 0 ? '（同比 ' + (((curVal - refVal) / refVal * 100) >= 0 ? '+' : '') + ((curVal - refVal) / refVal * 100).toFixed(1) + '%）' : '';
    };
    if (s.year_compare_last != null) {
      var v1 = s.year_compare_last / 100;
      lines.push('去年同月（' + (Number(yr) - 1) + '-' + mn + '）：¥' + v1.toFixed(2) + pctStr(v1));
    }
    if (s.year_compare_prev2 != null) {
      var v2 = s.year_compare_prev2 / 100;
      lines.push('前年同月（' + (Number(yr) - 2) + '-' + mn + '）：¥' + v2.toFixed(2) + pctStr(v2));
    }
    if (s.year_compare_prev3 != null) {
      var v3 = s.year_compare_prev3 / 100;
      lines.push('前前年同月（' + (Number(yr) - 3) + '-' + mn + '）：¥' + v3.toFixed(2) + pctStr(v3));
    }
  }

  // 成员明细
  lines.push(sep);
  lines.push('👥 成员分账明细');
  var mc2 = r.member_compare || {};
  var ptYr = Number(yr), ptMn = mn;
  (r.members || []).forEach(function(m) {
    var diff = parseFloat(m.diff);
    var diffStr;
    if (Math.abs(diff) < 0.01)   diffStr = '✅ 已平衡';
    else if (diff > 0)           diffStr = '+¥' + fmt(diff) + '（待收）';
    else                         diffStr = '-¥' + fmt(Math.abs(diff)) + '（需支付）';
    lines.push(m.name);
    lines.push('  应收 ¥' + fmt(m.should_get) + '　实收 ¥' + fmt(m.actual) + '　差额 ' + diffStr);
    var curC = Math.round(parseFloat(m.actual) * 100);
    var ptPct = function(ref) {
      if (!ref || ref <= 0) return '';
      var p = ((curC - ref) / ref * 100).toFixed(1);
      return (p >= 0 ? '+' : '') + p + '%';
    };
    var cmpItems = [];
    if (mc2.last  && mc2.last[m.name]  > 0) cmpItems.push((ptYr-1)+'-'+ptMn+'：¥'+(mc2.last[m.name]/100).toFixed(2)+'（'+ptPct(mc2.last[m.name])+'）');
    if (mc2.prev2 && mc2.prev2[m.name] > 0) cmpItems.push((ptYr-2)+'-'+ptMn+'：¥'+(mc2.prev2[m.name]/100).toFixed(2)+'（'+ptPct(mc2.prev2[m.name])+'）');
    if (mc2.prev3 && mc2.prev3[m.name] > 0) cmpItems.push((ptYr-3)+'-'+ptMn+'：¥'+(mc2.prev3[m.name]/100).toFixed(2)+'（'+ptPct(mc2.prev3[m.name])+'）');
    if (cmpItems.length) lines.push('  历史：' + cmpItems.join(' / '));
  });

  // 转账方案
  lines.push(sep);
  if ((r.transfers || []).length > 0) {
    lines.push('💸 最优转账方案');
    r.transfers.forEach(function(t) {
      lines.push(t.from + ' → ' + t.to + '：¥' + fmt(t.amount));
    });
  } else {
    lines.push('✅ 无需转账，账目已平衡');
  }
  lines.push(sep);

  return lines.join('\\n');
}

function copyPushText(btn) {
  var ta = document.getElementById('settlePushText');
  navigator.clipboard.writeText(ta.value).catch(function() {
    ta.select(); document.execCommand('copy');
  });
  btn.textContent = '已复制 ✓';
  btn.style.background = '#4caf50';
  setTimeout(function() { btn.textContent = '复制'; btn.style.background = '#6c63ff'; }, 1800);
}

async function pushSettle() {
  const id = document.getElementById('btnPush').dataset.id;
  if (!id) return alert('请先运行结算');
  if (!confirm('确认推送微信通知给所有成员？')) return;
  const res = await api('/api/settlements/'+id+'/push', { method:'POST' });
  if (res && res.ok) {
    const d = res.data;
    alert('推送完成：成功'+d.pushed+'人，失败'+d.failed+'人，跳过'+d.skipped+'人');
    loadSettlements();
  }
}

async function feishuSync() {
  const btn = document.getElementById('btnFeishu');
  const teamId = btn.dataset.team;
  const month  = btn.dataset.month;
  const [r1, r2] = await Promise.all([
    api('/api/feishu/sync-records',    {method:'POST', body:JSON.stringify({team_id:Number(teamId),month})}),
    api('/api/feishu/sync-settlement', {method:'POST', body:JSON.stringify({team_id:Number(teamId),month})}),
  ]);
  if (r1 && r1.ok && r2 && r2.ok) alert('飞书同步成功：台账'+r1.data.synced+'条，结算'+r2.data.synced+'条');
}

async function loadSettlements() {
  const res = await api('/api/settlements');
  const list = res ? res.data || [] : [];
  document.getElementById('settleListBody').innerHTML = list.map(function(s) {
    return '<tr>' +
      '<td>'+s.month+'</td>' +
      '<td>'+(teamsMap[s.team_id]||s.team_id)+'</td>' +
      '<td>¥'+(s.total_income/100).toFixed(2)+'</td>' +
      '<td>¥'+(s.total_expense/100).toFixed(2)+'</td>' +
      '<td>'+(s.year_compare_last  != null ? '¥'+(s.year_compare_last/100).toFixed(2) : '-')+'</td>' +
      '<td>'+(s.year_compare_prev2 != null ? '¥'+(s.year_compare_prev2/100).toFixed(2) : '-')+'</td>' +
      '<td>'+(s.year_compare_prev3 != null ? '¥'+(s.year_compare_prev3/100).toFixed(2) : '-')+'</td>' +
      '<td>'+(s.pushed_at ? '✅'+s.pushed_at.slice(0,10) : '-')+'</td>' +
      '<td>' +
        '<button class="btn btn-sm" onclick="viewSettle(this)" data-id="'+s.id+'">查看明细</button> ' +
        '<button class="btn btn-sm" style="color:#f44;border-color:#f44" onclick="deleteSettle('+s.id+')">删除</button>' +
      '</td>' +
      '</tr>';
  }).join('') || '<tr><td colspan="9">暂无结算记录</td></tr>';
  window._settlements = list;
}

function viewSettle(btn) {
  const id = parseInt(btn.dataset.id);
  const s = (window._settlements||[]).find(function(x){return x.id===id;});
  if (s) showSettleResult(s);
}

async function deleteSettle(id) {
  var s = (window._settlements||[]).find(function(x){ return x.id === id; });
  var label = s ? (s.month + ' ' + (teamsMap[s.team_id]||'')) : '该记录';
  if (!confirm('确认删除「' + label + '」的结算记录？此操作不可恢复。')) return;
  const res = await api('/api/settlements/' + id, { method: 'DELETE' });
  if (res && res.ok) loadSettlements();
}

initPage();
</script>`;
%>
<%- include('layout', { title, page, body, pageScript }) %>
