<%
const title = '成员管理';
const page  = 'users';
const body = `
<div class="page-header">
  <h2>成员管理</h2>
  <button class="btn btn-primary" onclick="showUserForm()">+ 新建成员</button>
</div>

<div id="userFormWrap" style="display:none" class="card form-card">
  <h3 id="userFormTitle">新建成员</h3>
  <form id="userForm">
    <input type="hidden" id="userId">
    <div class="form-row">
      <label>姓名 * <small>需与录入数据中的姓名完全一致</small></label>
      <input type="text" id="uName" required placeholder="如：张三">
    </div>
    <div class="form-row">
      <label>手机号</label>
      <input type="text" id="uMobile" placeholder="13800000000">
    </div>
    <div class="form-row">
      <label>所属团队 <small>可多选</small></label>
      <div id="uTeamsBox" style="display:flex;flex-wrap:wrap;gap:12px;padding:6px 0;min-height:32px"></div>
    </div>
    <div class="form-row">
      <label>角色</label>
      <select id="uRole">
        <option value="member">member（成员）</option>
        <option value="admin">admin（管理员）</option>
      </select>
    </div>
    <div class="form-row">
      <label>微信 OpenID <small>留空表示未绑定；填写后可与微信授权用户合并</small></label>
      <input type="text" id="uOpenid" placeholder="粘贴微信用户 OpenID" style="font-family:monospace;font-size:13px">
    </div>
    <div class="form-row" id="usernameRow">
      <label>登录用户名 <small>管理员建议填写</small></label>
      <input type="text" id="uUsername" placeholder="admin2">
    </div>
    <div class="form-row" id="passwordRow">
      <label>登录密码 <small>留空则不修改密码</small></label>
      <input type="password" id="uPassword" placeholder="新密码">
    </div>
    <div class="form-row">
      <label>京粉账户（收款账户名）</label>
      <input type="text" id="uJdAccount" placeholder="留空则与姓名相同，如：张三他妈">
    </div>
    <div class="form-row">
      <label>京粉实名人</label>
      <input type="text" id="uJfRealname" placeholder="京粉账号实名姓名">
    </div>
    <div class="form-row">
      <label>京粉手机号</label>
      <input type="text" id="uJfMobile" placeholder="京粉注册手机号">
    </div>
    <div class="form-row">
      <label>京粉密码</label>
      <input type="password" id="uJfPwd" placeholder="京粉密码">
    </div>
    <div class="form-actions">
      <button type="submit" class="btn btn-primary">保存</button>
      <button type="button" class="btn" onclick="hideUserForm()">取消</button>
    </div>
    <div id="userFormErr" class="error-msg" style="display:none"></div>
  </form>
</div>

<div class="table-wrap">
  <table class="data-table">
    <thead><tr><th>ID</th><th>姓名</th><th>手机号</th><th>角色</th><th>所属团队</th><th>微信 OpenID</th><th>状态</th><th>操作</th></tr></thead>
    <tbody id="userListBody"><tr><td colspan="8">加载中...</td></tr></tbody>
  </table>
</div>
`;
const pageScript = `<script>
let users = [], teamsMap = {}, allTeams = [], currentMe = null;

function escapeHtml(value) {
  return String(value == null ? '' : value)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

function buildOpenIdCell(openid) {
  if (!openid) return '<span style="color:#bbb">未绑定</span>';
  return '<div style="display:flex;align-items:flex-start;gap:8px;justify-content:flex-end">' +
    '<span title="' + escapeHtml(openid) + '" style="display:inline-block;max-width:220px;color:#6c63ff;white-space:normal;word-break:break-all;line-height:1.5;text-align:left">' +
      escapeHtml(openid) +
    '</span>' +
    '<button type="button" class="btn btn-sm" style="padding:2px 8px;font-size:12px;white-space:nowrap" onclick="copyText(' + JSON.stringify(openid) + ', this)">复制</button>' +
  '</div>';
}

async function loadAll() {
  const body = document.getElementById('userListBody');
  body.innerHTML = '<tr><td colspan="8">加载中...</td></tr>';

  const [meRes, ur, tr] = await Promise.all([api('/api/me'), api('/api/users'), api('/api/teams')]);
  currentMe = meRes && meRes.ok ? meRes.data : null;
  if (!ur || !tr || !ur.ok || !tr.ok) {
    body.innerHTML = '<tr><td colspan="8">加载失败，请刷新后重试</td></tr>';
    return;
  }

  users = ur.data || [];
  allTeams = tr.data || [];
  teamsMap = Object.fromEntries(allTeams.map(function(t) { return [t.id, t.name]; }));

  if (currentMe && currentMe.user && currentMe.user.role !== 'admin') {
    var adminOpt = document.querySelector('#uRole option[value="admin"]');
    if (adminOpt) adminOpt.remove();
  }

  body.innerHTML = users.map(function(u) {
    var teamNames = (u.team_ids && u.team_ids.length)
      ? u.team_ids.map(function(id) { return teamsMap[id] || id; }).join(', ')
      : '-';

    return '<tr>' +
      '<td>' + u.id + '</td>' +
      '<td><strong>' + escapeHtml(u.name || '-') + '</strong></td>' +
      '<td>' + escapeHtml(u.mobile || '-') + '</td>' +
      '<td><span class="badge">' + escapeHtml(u.role) + '</span></td>' +
      '<td>' + escapeHtml(teamNames) + '</td>' +
      '<td style="font-size:12px;font-family:monospace">' + buildOpenIdCell(u.openid) + '</td>' +
      '<td>' + (u.status ? '正常' : '停用') + '</td>' +
      '<td>' +
        '<button class="btn btn-sm" onclick="editUser(' + u.id + ')">编辑</button> ' +
        '<button class="btn btn-sm" style="color:#f44;border-color:#f44" onclick="deleteUser(' + u.id + ')">删除</button>' +
      '</td>' +
      '</tr>';
  }).join('') || '<tr><td colspan="8">暂无成员</td></tr>';
}

function renderTeamCheckboxes(selectedIds) {
  document.getElementById('uTeamsBox').innerHTML = allTeams.map(function(t) {
    var checked = selectedIds && selectedIds.indexOf(t.id) !== -1 ? ' checked' : '';
    return '<label style="display:flex;align-items:center;gap:5px;cursor:pointer;padding:4px 10px;border:1px solid #ddd;border-radius:6px;' +
           (checked ? 'background:#f0f4ff;border-color:#6c63ff;' : '') + '">' +
           '<input type="checkbox" value="' + t.id + '"' + checked + ' onchange="onTeamCheck(this)"> ' + escapeHtml(t.name) + '</label>';
  }).join('');
}

function onTeamCheck(cb) {
  var label = cb.parentNode;
  if (cb.checked) {
    label.style.background = '#f0f4ff';
    label.style.borderColor = '#6c63ff';
  } else {
    label.style.background = '';
    label.style.borderColor = '#ddd';
  }
}

function showUserForm(user) {
  document.getElementById('userFormWrap').style.display = 'block';
  document.getElementById('userFormTitle').textContent = user ? '编辑成员' : '新建成员';
  document.getElementById('userId').value = user ? user.id : '';
  document.getElementById('uName').value = user ? user.name || '' : '';
  document.getElementById('uMobile').value = user ? user.mobile || '' : '';
  document.getElementById('uRole').value = user ? user.role : 'member';
  document.getElementById('uUsername').value = user ? user.username || '' : '';
  document.getElementById('uPassword').value = '';
  document.getElementById('uOpenid').value = user ? user.openid || '' : '';
  document.getElementById('uJdAccount').value = user ? user.jd_account || '' : '';
  document.getElementById('uJfRealname').value = user ? user.jingfen_realname || '' : '';
  document.getElementById('uJfMobile').value = user ? user.jingfen_mobile || '' : '';
  document.getElementById('uJfPwd').value = '';
  document.getElementById('userFormErr').style.display = 'none';
  renderTeamCheckboxes(user ? user.team_ids || [] : []);
}

function hideUserForm() {
  document.getElementById('userFormWrap').style.display = 'none';
}

function editUser(id) {
  showUserForm(users.find(function(u) { return u.id === id; }));
}

document.getElementById('userForm').addEventListener('submit', async function(e) {
  e.preventDefault();
  const id = document.getElementById('userId').value;
  var checked = document.querySelectorAll('#uTeamsBox input:checked');
  const body = {
    name: document.getElementById('uName').value,
    mobile: document.getElementById('uMobile').value,
    role: document.getElementById('uRole').value,
    username: document.getElementById('uUsername').value || null,
    team_ids: Array.from(checked).map(function(cb) { return Number(cb.value); }),
    openid: document.getElementById('uOpenid').value || null,
    jd_account: document.getElementById('uJdAccount').value || null,
    jingfen_realname: document.getElementById('uJfRealname').value || null,
    jingfen_mobile: document.getElementById('uJfMobile').value || null
  };

  const pwd = document.getElementById('uPassword').value;
  if (pwd) body.password = pwd;

  const jfPwd = document.getElementById('uJfPwd').value;
  if (jfPwd) body.jingfen_password = jfPwd;

  const res = await api(id ? '/api/users/' + id : '/api/users', {
    method: id ? 'PUT' : 'POST',
    body: JSON.stringify(body)
  });

  if (res && res.ok) {
    hideUserForm();
    loadAll();
  } else {
    var err = document.getElementById('userFormErr');
    err.textContent = (res && res.message) || '保存失败';
    err.style.display = 'block';
  }
});

async function deleteUser(id) {
  var user = users.find(function(u) { return u.id === id; });
  var name = user ? (user.name || '该成员') : '该成员';
  if (!confirm('确认删除成员「' + name + '」？此操作不可恢复。')) return;

  var res = await api('/api/users/' + id, { method: 'DELETE' });
  if (res && res.ok) loadAll();
}

async function copyText(text, btn) {
  var copied = false;
  try {
    if (navigator.clipboard && window.isSecureContext) {
      await navigator.clipboard.writeText(text);
      copied = true;
    }
  } catch (e) {}

  if (!copied) {
    var ta = document.createElement('textarea');
    ta.value = text;
    ta.setAttribute('readonly', 'readonly');
    ta.style.position = 'fixed';
    ta.style.top = '-9999px';
    document.body.appendChild(ta);
    ta.focus();
    ta.select();
    ta.setSelectionRange(0, ta.value.length);
    try { copied = document.execCommand('copy'); } catch (e) {}
    document.body.removeChild(ta);
  }

  if (btn) {
    var oldText = btn.textContent;
    btn.textContent = copied ? '已复制' : '复制失败';
    setTimeout(function() { btn.textContent = oldText; }, 1600);
  } else if (!copied) {
    alert('复制失败，请手动复制');
  }
}

loadAll();
</script>`;
%>
<%- include('layout', { title, page, body, pageScript }) %>
