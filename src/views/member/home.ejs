<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>我的收益</title>
  <link rel="stylesheet" href="/member.css">
  <style>
    .m-edit-btn { font-size:13px; color:#6c63ff; background:none; border:1px solid #6c63ff; border-radius:12px; padding:3px 12px; cursor:pointer; }
    .m-modal-mask { display:none; position:fixed; inset:0; background:rgba(0,0,0,.45); z-index:100; overflow-y:auto; }
    .m-modal-mask.show { display:flex; align-items:flex-end; }
    .m-modal { background:#fff; border-radius:16px 16px 0 0; width:100%; padding:24px 20px 36px; }
    .m-modal h3 { margin:0 0 18px; font-size:17px; }
    .m-field { margin-bottom:14px; }
    .m-field label { display:block; font-size:13px; color:#666; margin-bottom:5px; }
    .m-field input[type=text],.m-field input[type=password],.m-field input[type=tel],.m-field input[type=number],.m-field input[type=month],.m-field select,.m-field textarea {
      width:100%; box-sizing:border-box; border:1px solid #ddd; border-radius:8px; padding:10px 12px; font-size:15px; background:#fff;
    }
    .m-field input:focus,.m-field select:focus,.m-field textarea:focus { outline:none; border-color:#6c63ff; }
    .m-modal-btns { display:flex; gap:10px; margin-top:20px; }
    .m-modal-btns button { flex:1; padding:12px; border-radius:10px; border:none; font-size:15px; cursor:pointer; }
    .m-btn-cancel { background:#f0f0f0; color:#333; }
    .m-btn-save { background:#6c63ff; color:#fff; }
    .m-report-item { background:#f0f4ff; border-radius:12px; padding:12px 14px; margin-bottom:8px; display:flex; align-items:center; justify-content:space-between; }
    .m-report-amount { font-size:18px; font-weight:700; color:#6c63ff; }
    .m-report-label { font-size:13px; color:#555; }
    .m-report-meta { font-size:11px; color:#999; margin-top:2px; }
    .m-report-expense { background:#fff3f3; }
    .m-report-expense .m-report-amount { color:#f44336; }
    .m-img-preview { margin-top:8px; max-width:100%; max-height:160px; border-radius:8px; display:none; }
    .m-upload-label { display:inline-block; padding:8px 16px; background:#f0f0f0; border-radius:8px; font-size:14px; cursor:pointer; }
    .m-header-row { display:flex; align-items:center; justify-content:space-between; }
  </style>
</head>
<body>
  <div class="m-app">
    <div class="m-header">
      <h1>我的收益</h1>
      <a href="/h5/history" class="m-link">历史记录 →</a>
    </div>

    <div class="m-card m-user-card">
      <div style="display:flex;align-items:center;gap:12px">
        <div class="m-avatar">👤</div>
        <div class="m-user-info" style="flex:1">
          <div id="userName" class="m-name">加载中...</div>
          <div id="teamName" class="m-team">-</div>
        </div>
        <button class="m-edit-btn" onclick="openEdit()">编辑资料</button>
      </div>
    </div>

    <div id="teamTabsWrap" style="display:none;gap:8px;overflow-x:auto;padding:0 16px 8px;margin-bottom:4px"></div>

    <div class="m-month-bar">
      <button onclick="prevMonth()">‹</button>
      <span id="monthLabel">-</span>
      <button onclick="nextMonth()">›</button>
    </div>

    <div class="m-card">
      <div class="m-header-row" style="margin-bottom:12px">
        <span class="m-card-title" style="margin:0">本月收益上报</span>
        <button class="m-edit-btn" onclick="openReport()">填写上报</button>
      </div>
      <div id="reportStatus"><div class="m-empty">本月暂未上报</div></div>
    </div>

    <div id="incomeCards" class="m-stats"></div>

    <div id="compareSection" style="display:none" class="m-card">
      <div class="m-card-title">历史对比</div>
      <div id="compareContent" class="m-compare"></div>
    </div>

    <div id="detailSection" class="m-card">
      <div class="m-card-title">本月明细</div>
      <div id="recordList" class="m-record-list">加载中...</div>
    </div>
  </div>

  <!-- 编辑资料 -->
  <div class="m-modal-mask" id="editMask">
    <div class="m-modal">
      <h3>编辑个人资料</h3>
      <div class="m-field">
        <label>真实姓名（需与账单中姓名一致）</label>
        <input type="text" id="editName" placeholder="请输入真实姓名">
      </div>
      <div class="m-field">
        <label>京粉实名人</label>
        <input type="text" id="editJfRealname" placeholder="京粉账号实名人姓名">
      </div>
      <div class="m-field">
        <label>京粉手机号</label>
        <input type="tel" id="editJfMobile" placeholder="请输入京粉注册手机号">
      </div>
      <div class="m-field">
        <label>京粉密码</label>
        <input type="password" id="editJfPwd" placeholder="请输入京粉密码">
      </div>
      <div class="m-modal-btns">
        <button class="m-btn-cancel" onclick="closeEdit()">取消</button>
        <button class="m-btn-save" onclick="saveProfile()">保存</button>
      </div>
    </div>
  </div>

  <!-- 上报收益 -->
  <div class="m-modal-mask" id="reportMask">
    <div class="m-modal">
      <h3>上报本月收益</h3>
      <div class="m-field" id="reportTeamFieldWrap" style="display:none">
        <label>所属团队</label>
        <select id="reportTeamSelect"></select>
      </div>
      <div class="m-field">
        <label>月份</label>
        <input type="month" id="reportMonth">
      </div>
      <div class="m-field">
        <label>类型</label>
        <select id="reportItemType" onchange="onReportTypeChange()">
          <option value="income_jingfen">收入 — 京粉收入</option>
          <option value="income_taobao">收入 — 淘宝收入</option>
          <option value="expense">支出</option>
        </select>
      </div>
      <div class="m-field">
        <label id="reportAmountLabel">本月京粉收益（元）</label>
        <input type="number" id="reportAmount" step="0.01" min="0" placeholder="0.00">
      </div>
      <div class="m-field" id="reportScreenshotField">
        <label>收益截图</label>
        <label class="m-upload-label" for="reportImg">📷 选择图片</label>
        <input type="file" id="reportImg" accept="image/*" style="display:none" onchange="previewImg(this)">
        <img id="imgPreview" class="m-img-preview">
      </div>
      <div class="m-field">
        <label id="reportNoteLabel">备注（可选）</label>
        <input type="text" id="reportNote" placeholder="可选说明">
      </div>
      <div class="m-modal-btns">
        <button class="m-btn-cancel" onclick="closeReport()">取消</button>
        <button class="m-btn-save" id="btnSubmitReport" onclick="submitReport()">提交</button>
      </div>
    </div>
  </div>

  <script src="/member.js"></script>
  <script>
    var token = '';
    var currentUser = null;
    var currentMonth = new Date().toISOString().slice(0,7);
    var currentTeamId = null;
    var userTeams = [];

    function getToken() {
      var hash = location.hash.replace('#','');
      var params = new URLSearchParams(hash);
      var t = params.get('token') || sessionStorage.getItem('member_token');
      if (t) { sessionStorage.setItem('member_token', t); location.hash = ''; }
      return t;
    }

    async function memberApi(url, options) {
      var opts = options || {};
      var headers = { Authorization: 'Bearer ' + token };
      if (!(opts.body instanceof FormData)) headers['Content-Type'] = 'application/json';
      opts.headers = Object.assign(headers, opts.headers || {});
      var res = await fetch(url, opts);
      if (res.status === 401) { location.href = '/auth/wechat/start'; return null; }
      return res.json();
    }

    function prevMonth() {
      var parts = currentMonth.split('-').map(Number);
      var y = parts[0], m = parts[1];
      currentMonth = m === 1 ? (y-1)+'-12' : y+'-'+(m-1).toString().padStart(2,'0');
      loadAll();
    }
    function nextMonth() {
      var parts = currentMonth.split('-').map(Number);
      var y = parts[0], m = parts[1];
      var today = new Date().toISOString().slice(0,7);
      var next = m === 12 ? (y+1)+'-01' : y+'-'+(m+1).toString().padStart(2,'0');
      if (next > today) return;
      currentMonth = next;
      loadAll();
    }

    function renderTeamTabs() {
      var wrap = document.getElementById('teamTabsWrap');
      wrap.style.display = 'flex';
      wrap.innerHTML = userTeams.map(function(t) {
        return '<button style="flex:none;padding:6px 16px;border-radius:20px;border:1.5px solid #6c63ff;font-size:13px;cursor:pointer;white-space:nowrap;' +
               (t.id === currentTeamId ? 'background:#6c63ff;color:#fff' : 'background:none;color:#6c63ff') +
               '" onclick="switchTeam(' + t.id + ')">' + t.name + '</button>';
      }).join('');
    }

    function switchTeam(id) {
      currentTeamId = id;
      var team = userTeams.find(function(t) { return t.id === id; });
      document.getElementById('teamName').textContent = team ? team.name : '-';
      if (userTeams.length > 1) renderTeamTabs();
      loadAll();
    }

    function onReportTypeChange() {
      var type = document.getElementById('reportItemType').value;
      var label = document.getElementById('reportAmountLabel');
      var noteLabel = document.getElementById('reportNoteLabel');
      if (type === 'income_jingfen') { label.textContent = '本月京粉收益（元）'; noteLabel.textContent = '备注（可选）'; }
      else if (type === 'income_taobao') { label.textContent = '本月淘宝收益（元）'; noteLabel.textContent = '备注（可选）'; }
      else { label.textContent = '支出金额（元）'; noteLabel.textContent = '支出说明（必填）'; }
    }

    function openEdit() {
      document.getElementById('editName').value = currentUser ? currentUser.name||'' : '';
      document.getElementById('editJfRealname').value = currentUser ? currentUser.jingfen_realname||'' : '';
      document.getElementById('editJfMobile').value = currentUser ? currentUser.jingfen_mobile||'' : '';
      document.getElementById('editJfPwd').value = '';
      document.getElementById('editMask').classList.add('show');
    }
    function closeEdit() { document.getElementById('editMask').classList.remove('show'); }

    async function saveProfile() {
      var body = {
        name: document.getElementById('editName').value.trim(),
        jingfen_realname: document.getElementById('editJfRealname').value.trim(),
        jingfen_mobile: document.getElementById('editJfMobile').value.trim(),
      };
      var pwd = document.getElementById('editJfPwd').value;
      if (pwd) body.jingfen_password = pwd;
      var res = await memberApi('/member/profile', { method:'PUT', body: JSON.stringify(body) });
      if (res && res.ok) { closeEdit(); init(); } else { alert('保存失败，请重试'); }
    }

    function openReport() {
      var teamFieldWrap = document.getElementById('reportTeamFieldWrap');
      if (userTeams.length > 1) {
        teamFieldWrap.style.display = 'block';
        document.getElementById('reportTeamSelect').innerHTML = userTeams.map(function(t) {
          return '<option value="' + t.id + '"' + (t.id === currentTeamId ? ' selected' : '') + '>' + t.name + '</option>';
        }).join('');
      } else {
        teamFieldWrap.style.display = 'none';
      }
      document.getElementById('reportMonth').value = currentMonth;
      document.getElementById('reportAmount').value = '';
      document.getElementById('reportNote').value = '';
      document.getElementById('reportImg').value = '';
      document.getElementById('imgPreview').style.display = 'none';
      document.getElementById('reportItemType').value = 'income_jingfen';
      onReportTypeChange();
      document.getElementById('reportMask').classList.add('show');
    }
    function closeReport() { document.getElementById('reportMask').classList.remove('show'); }

    function previewImg(input) {
      var file = input.files[0];
      if (!file) return;
      var reader = new FileReader();
      reader.onload = function(e) {
        var img = document.getElementById('imgPreview');
        img.src = e.target.result;
        img.style.display = 'block';
      };
      reader.readAsDataURL(file);
    }

    async function submitReport() {
      var month = document.getElementById('reportMonth').value;
      var amount = document.getElementById('reportAmount').value;
      var itemTypeRaw = document.getElementById('reportItemType').value;
      var note = document.getElementById('reportNote').value;
      if (!month || amount === '') { alert('请填写月份和金额'); return; }
      if (itemTypeRaw === 'expense' && !note.trim()) { alert('支出请填写备注说明'); return; }

      var teamId = currentTeamId;
      if (userTeams.length > 1) teamId = Number(document.getElementById('reportTeamSelect').value);
      if (!teamId) { alert('请选择团队'); return; }

      var itemType, itemName;
      if (itemTypeRaw === 'income_jingfen') { itemType = 'income'; itemName = '京粉收入'; }
      else if (itemTypeRaw === 'income_taobao') { itemType = 'income'; itemName = '淘宝收入'; }
      else { itemType = 'expense'; itemName = '支出'; }

      var btn = document.getElementById('btnSubmitReport');
      btn.disabled = true; btn.textContent = '提交中...';

      var fd = new FormData();
      fd.append('month', month);
      fd.append('amount', amount);
      fd.append('team_id', teamId);
      fd.append('item_type', itemType);
      fd.append('item_name', itemName);
      fd.append('note', note);
      var imgFile = document.getElementById('reportImg').files[0];
      if (imgFile) fd.append('screenshot', imgFile);

      var res = await fetch('/member/report', {
        method: 'POST',
        headers: { Authorization: 'Bearer ' + token },
        body: fd,
      });
      var data = await res.json();
      btn.disabled = false; btn.textContent = '提交';
      if (data && data.ok) { closeReport(); loadReport(); loadIncome(); }
      else { alert(data.message || '提交失败'); }
    }

    async function loadReport() {
      if (!currentTeamId) {
        document.getElementById('reportStatus').innerHTML = '<div class="m-empty">未绑定团队</div>';
        return;
      }
      var res = await memberApi('/member/report?month=' + currentMonth + '&team_id=' + currentTeamId);
      var el = document.getElementById('reportStatus');
      var reports = (res && res.data) ? res.data : [];
      if (reports.length) {
        el.innerHTML = reports.map(function(r) {
          var isExpense = r.item_type === 'expense';
          return '<div class="m-report-item' + (isExpense ? ' m-report-expense' : '') + '">' +
            '<div>' +
              '<div class="m-report-label">' + r.item_name + '</div>' +
              '<div class="m-report-meta">已上报 · ' + (r.updated_at||'').slice(0,10) + (r.note ? ' · '+r.note : '') + '</div>' +
            '</div>' +
            '<div style="text-align:right">' +
              '<div class="m-report-amount">' + (isExpense ? '-' : '') + '¥' + r.amount.toFixed(2) + '</div>' +
              (r.screenshot ? '<img src="' + r.screenshot + '" style="margin-top:4px;height:36px;border-radius:4px">' : '') +
            '</div>' +
          '</div>';
        }).join('');
      } else {
        el.innerHTML = '<div class="m-empty">本月暂未上报</div>';
      }
    }

    async function init() {
      token = getToken();
      if (!token) { location.href = '/auth/wechat/start'; return; }
      var me = await memberApi('/member/me');
      if (!me || !me.ok) return;
      currentUser = me.data.user;
      userTeams = me.data.teams || [];
      document.getElementById('userName').textContent = currentUser.name || '未设置姓名';
      if (userTeams.length === 0) {
        document.getElementById('teamName').textContent = '未绑定团队';
        currentTeamId = null;
        document.getElementById('incomeCards').innerHTML = '<div class="m-empty">未绑定团队，请联系管理员</div>';
        document.getElementById('recordList').innerHTML = '';
      } else if (userTeams.length === 1) {
        currentTeamId = userTeams[0].id;
        document.getElementById('teamName').textContent = userTeams[0].name;
        loadAll();
      } else {
        currentTeamId = userTeams[0].id;
        document.getElementById('teamName').textContent = userTeams[0].name;
        renderTeamTabs();
        loadAll();
      }
    }

    function loadAll() {
      document.getElementById('monthLabel').textContent = currentMonth;
      loadReport();
      loadIncome();
    }

    async function loadIncome() {
      if (!currentTeamId) return;
      var res = await memberApi('/member/income/current?month=' + currentMonth + '&team_id=' + currentTeamId);
      if (!res || !res.ok) return;
      var d = res.data;
      if (!d) {
        document.getElementById('incomeCards').innerHTML = '<div class="m-empty">未绑定团队或无数据</div>';
        document.getElementById('recordList').innerHTML = '<div class="m-empty">暂无明细</div>';
        return;
      }
      var s = d.settlement;
      if (s) {
        var diffCls = parseFloat(s.diff) >= 0 ? 'green' : 'red';
        document.getElementById('incomeCards').innerHTML =
          '<div class="m-stat-card highlight"><div class="m-stat-label">应收金额</div><div class="m-stat-value">¥' + s.should_get + '</div></div>' +
          '<div class="m-stat-card ' + diffCls + '"><div class="m-stat-label">差额</div><div class="m-stat-value">¥' + s.diff + '</div></div>';
      } else {
        document.getElementById('incomeCards').innerHTML = '<div class="m-empty">本月暂未结算</div>';
      }
      var cmp = d.year_compare;
      if (cmp && (cmp.last != null || cmp.prev2 != null)) {
        document.getElementById('compareSection').style.display = 'block';
        var cmpHtml = '';
        if (cmp.last  != null) cmpHtml += '<div class="m-compare-item"><span>去年同月</span><strong>¥' + cmp.last  + '</strong></div>';
        if (cmp.prev2 != null) cmpHtml += '<div class="m-compare-item"><span>前年同月</span><strong>¥' + cmp.prev2 + '</strong></div>';
        document.getElementById('compareContent').innerHTML = cmpHtml;
      }
      var TYPES = { income:'收入', tax:'退税', expense:'支出', adjust:'调整' };
      if (d.records && d.records.length) {
        document.getElementById('recordList').innerHTML = d.records.map(function(r) {
          return '<div class="m-record-item">' +
            '<span class="m-record-type type-' + r.item_type + '">' + (TYPES[r.item_type]||r.item_type) + '</span>' +
            '<span class="m-record-name">' + (r.item_name||r.item_type) + '</span>' +
            '<span class="m-record-amount ' + (r.item_type==='expense'?'red':'') + '">¥' + r.amount + '</span>' +
            '</div>';
        }).join('');
      } else {
        document.getElementById('recordList').innerHTML = '<div class="m-empty">本月暂无明细</div>';
      }
    }

    init();
  </script>
</body>
</html>
