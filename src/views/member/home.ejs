<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>我的收益</title>
  <link rel="stylesheet" href="/member.css">
</head>
<body>
  <div class="m-app">
    <div class="m-header">
      <h1>我的收益</h1>
      <a href="/h5/history" class="m-link">历史记录 →</a>
    </div>

    <div id="userInfo" class="m-card m-user-card">
      <div class="m-avatar">👤</div>
      <div class="m-user-info">
        <div id="userName" class="m-name">加载中...</div>
        <div id="teamName" class="m-team">-</div>
      </div>
    </div>

    <div class="m-month-bar">
      <button onclick="prevMonth()">‹</button>
      <span id="monthLabel">-</span>
      <button onclick="nextMonth()">›</button>
    </div>

    <div id="incomeCards" class="m-stats">
      <div class="m-stat-card loading">加载中...</div>
    </div>

    <div id="compareSection" style="display:none" class="m-card">
      <div class="m-card-title">历史对比</div>
      <div id="compareContent" class="m-compare"></div>
    </div>

    <div id="detailSection" class="m-card">
      <div class="m-card-title">本月明细</div>
      <div id="recordList" class="m-record-list">加载中...</div>
    </div>
  </div>

  <script src="/member.js"></script>
  <script>
    var token = '';
    var currentUser = null;
    var currentMonth = new Date().toISOString().slice(0,7);

    function getToken() {
      var hash = location.hash.replace('#','');
      var params = new URLSearchParams(hash);
      var t = params.get('token') || sessionStorage.getItem('member_token');
      if (t) { sessionStorage.setItem('member_token', t); location.hash = ''; }
      return t;
    }

    async function memberApi(url) {
      var res = await fetch(url, { headers: { Authorization: 'Bearer ' + token } });
      if (res.status === 401) { location.href = '/auth/wechat/start'; return null; }
      return res.json();
    }

    function prevMonth() {
      var parts = currentMonth.split('-').map(Number);
      var y = parts[0], m = parts[1];
      currentMonth = m === 1 ? (y-1)+'-12' : y+'-'+(m-1).toString().padStart(2,'0');
      loadIncome();
    }
    function nextMonth() {
      var parts = currentMonth.split('-').map(Number);
      var y = parts[0], m = parts[1];
      var today = new Date().toISOString().slice(0,7);
      var next = m === 12 ? (y+1)+'-01' : y+'-'+(m+1).toString().padStart(2,'0');
      if (next > today) return;
      currentMonth = next;
      loadIncome();
    }

    async function init() {
      token = getToken();
      if (!token) { location.href = '/auth/wechat/start'; return; }
      var me = await memberApi('/member/me');
      if (!me || !me.ok) return;
      currentUser = me.data.user;
      document.getElementById('userName').textContent = currentUser.name || '未设置姓名';
      document.getElementById('teamName').textContent = me.data.team ? me.data.team.name : '未绑定团队';
      loadIncome();
    }

    async function loadIncome() {
      document.getElementById('monthLabel').textContent = currentMonth;
      var res = await memberApi('/member/income/current?month=' + currentMonth);
      if (!res || !res.ok) return;
      var d = res.data;
      if (!d) {
        document.getElementById('incomeCards').innerHTML = '<div class="m-empty">未绑定团队或无数据</div>';
        document.getElementById('recordList').innerHTML = '<div class="m-empty">暂无明细</div>';
        return;
      }

      // 结算卡片
      var s = d.settlement;
      if (s) {
        var diffCls = parseFloat(s.diff) >= 0 ? 'green' : 'red';
        document.getElementById('incomeCards').innerHTML =
          '<div class="m-stat-card highlight"><div class="m-stat-label">应收金额</div><div class="m-stat-value">¥' + s.should_get + '</div></div>' +
          '<div class="m-stat-card ' + diffCls + '"><div class="m-stat-label">差额</div><div class="m-stat-value">¥' + s.diff + '</div></div>';
      } else {
        document.getElementById('incomeCards').innerHTML = '<div class="m-empty">本月暂未结算</div>';
      }

      // 年同比
      var cmp = d.year_compare;
      if (cmp && (cmp.last != null || cmp.prev2 != null)) {
        document.getElementById('compareSection').style.display = 'block';
        var cmpHtml = '';
        if (cmp.last  != null) cmpHtml += '<div class="m-compare-item"><span>去年同月</span><strong>¥' + cmp.last  + '</strong></div>';
        if (cmp.prev2 != null) cmpHtml += '<div class="m-compare-item"><span>前年同月</span><strong>¥' + cmp.prev2 + '</strong></div>';
        document.getElementById('compareContent').innerHTML = cmpHtml;
      }

      // 明细
      var TYPES = { income:'收入', tax:'退税', expense:'支出', adjust:'调整' };
      if (d.records && d.records.length) {
        document.getElementById('recordList').innerHTML = d.records.map(function(r) {
          return '<div class="m-record-item">' +
            '<span class="m-record-type type-' + r.item_type + '">' + (TYPES[r.item_type] || r.item_type) + '</span>' +
            '<span class="m-record-name">' + (r.item_name || r.item_type) + '</span>' +
            '<span class="m-record-amount ' + (r.item_type==='expense'?'red':'') + '">¥' + r.amount + '</span>' +
            '</div>';
        }).join('');
      } else {
        document.getElementById('recordList').innerHTML = '<div class="m-empty">本月暂无明细</div>';
      }
    }

    init();
  </script>
</body>
</html>
