<%
const title = '团队管理';
const page  = 'teams';
const body = `
<div class="page-header">
  <h2>团队管理</h2>
  <button class="btn btn-primary" onclick="showTeamForm()">+ 新建团队</button>
</div>

<div id="teamFormWrap" style="display:none" class="card form-card">
  <h3 id="formTitle">新建团队</h3>
  <form id="teamForm">
    <input type="hidden" id="teamId">
    <div class="form-row">
      <label>团队名称 *</label>
      <input type="text" id="tName" required placeholder="如：性价屋Z团队">
    </div>
    <div class="form-row">
      <label>分账规则 *</label>
      <select id="tRuleType" onchange="onRuleChange()">
        <option value="zteam">Z团队（负责人按比例+报销支出，其余人平分剩余）</option>
        <option value="standard">标准（负责人按比例，其余人平分剩余，支出从总额扣除）</option>
        <option value="custom">自定义（每人固定分成比例）</option>
      </select>
    </div>

    <div id="leaderFields" style="border:1px solid #e8e8e8;border-radius:8px;padding:14px;margin-top:8px">
      <div style="font-size:13px;color:#888;margin-bottom:10px">负责人配置</div>
      <div id="memberTags" style="display:none;margin-bottom:10px;font-size:13px;color:#555">
        <span style="color:#888">团队成员：</span>
        <span id="memberTagList"></span>
      </div>
      <div class="form-grid">
        <div class="form-row">
          <label>负责人姓名 *</label>
          <input type="text" id="tLeaderName" placeholder="与成员管理中的姓名完全一致" list="leaderSuggestions" autocomplete="off">
          <datalist id="leaderSuggestions"></datalist>
        </div>
        <div class="form-row">
          <label>负责人分成比例（%）</label>
          <input type="number" id="tLeaderRatio" step="1" min="0" max="100" value="20" placeholder="20">
        </div>
      </div>
      <div id="reimburseRow" class="form-row">
        <label style="display:flex;align-items:center;gap:8px;cursor:pointer">
          <input type="checkbox" id="tReimburse" checked style="width:auto">
          负责人报销所有支出（支出全额加入负责人应收）
        </label>
      </div>
    </div>

    <div id="customFields" style="display:none;border:1px solid #e8e8e8;border-radius:8px;padding:14px;margin-top:8px">
      <div style="font-size:13px;color:#888;margin-bottom:10px">各成员分成比例（加起来须等于100%）</div>
      <div id="allocationsWrap"></div>
      <button type="button" class="btn" style="margin-top:8px" onclick="addAllocationEditable('','')">+ 手动添加成员</button>
      <div id="ratioSum" style="margin-top:8px;font-size:13px;color:#666"></div>
    </div>

    <div id="ruleMembersSection" style="display:none;border:1px solid #c8d8ff;border-radius:8px;padding:14px;margin-top:12px;background:#f8f9ff">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px">
        <div>
          <span style="font-size:14px;font-weight:600;color:#333">成员分账配置</span>
          <span style="font-size:12px;color:#888;margin-left:8px">（设置后优先于上方规则；留空则用上方规则）</span>
        </div>
        <button type="button" class="btn btn-sm" onclick="clearRuleMembers()">清空</button>
      </div>
      <div id="ruleMembersWrap"></div>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn btn-primary">保存</button>
      <button type="button" class="btn" onclick="hideTeamForm()">取消</button>
    </div>
    <div id="teamFormErr" class="error-msg" style="display:none"></div>
  </form>
</div>

<div class="table-wrap">
  <table class="data-table">
    <thead><tr><th>ID</th><th>团队名称</th><th>规则类型</th><th>分成说明</th><th>状态</th><th>操作</th></tr></thead>
    <tbody id="teamListBody"><tr><td colspan="6">加载中...</td></tr></tbody>
  </table>
</div>
`;
const pageScript = `<script>
let teams = [];
let currentFormMembers = [];

function describeRule(t) {
  var cfg = t.rule_config || {};
  if (t.rule_type === 'zteam') {
    var r = cfg.leader_ratio != null ? (cfg.leader_ratio * 100).toFixed(0) : '?';
    return (cfg.leader_name || '（未设置负责人）') + ' 拿' + r + '% + 报销支出；其余平分';
  }
  if (t.rule_type === 'standard') {
    var r = cfg.leader_ratio != null ? (cfg.leader_ratio * 100).toFixed(0) : '?';
    return (cfg.leader_name || '（未设置负责人）') + ' 拿' + r + '%；其余平分';
  }
  if (t.rule_type === 'custom') {
    var allocs = cfg.allocations || [];
    return allocs.map(function(a){ return a.name + ' ' + (a.ratio*100).toFixed(0) + '%'; }).join('，') || '（未配置）';
  }
  return '-';
}

async function loadTeams() {
  const res = await api('/api/teams');
  if (!res) return;
  teams = res.data || [];
  document.getElementById('teamListBody').innerHTML = teams.map(function(t) {
    return '<tr>' +
      '<td>' + t.id + '</td>' +
      '<td><strong>' + t.name + '</strong></td>' +
      '<td><span class="badge">' + t.rule_type + '</span></td>' +
      '<td style="font-size:13px">' + describeRule(t) + '</td>' +
      '<td>' + (t.status ? '✅启用' : '🚫停用') + '</td>' +
      '<td><button class="btn btn-sm" onclick="editTeam(' + t.id + ')">编辑</button></td>' +
      '</tr>';
  }).join('') || '<tr><td colspan="6">暂无团队</td></tr>';
}

function pickLeader(i) {
  if (currentFormMembers[i]) document.getElementById('tLeaderName').value = currentFormMembers[i].name;
}

function renderRuleMembers(members, savedRuleMembers) {
  var wrap = document.getElementById('ruleMembersWrap');
  if (members.length === 0) {
    wrap.innerHTML = '<div style="color:#aaa;font-size:13px">请先在成员管理中为该团队分配成员</div>';
    return;
  }
  var ruleMap = {};
  (savedRuleMembers || []).forEach(function(r) { ruleMap[r.member_name] = r; });
  wrap.innerHTML = members.map(function(m, i) {
    var rm = ruleMap[m.name] || {};
    var mode = rm.rule_mode || 'ratio';
    var val = mode === 'formula' ? (rm.formula || '') : (rm.ratio != null ? (rm.ratio * 100).toFixed(0) : '');
    return '<div class="rm-row" data-name="' + m.name + '" style="display:flex;gap:8px;margin-bottom:8px;align-items:center">' +
      '<span style="flex:2;font-size:14px">' + m.name + '</span>' +
      '<select class="rm-mode" onchange="onRmModeChange(this)" style="flex:1;border:1px solid #ddd;border-radius:6px;padding:7px 8px;font-size:13px">' +
        '<option value="ratio"' + (mode === 'ratio' ? ' selected' : '') + '>固定比例</option>' +
        '<option value="formula"' + (mode === 'formula' ? ' selected' : '') + '>公式</option>' +
      '</select>' +
      '<input class="rm-val" type="text" value="' + val + '" ' +
        'placeholder="' + (mode === 'ratio' ? '如：20（%）' : '如：income*0.2') + '" ' +
        'style="flex:2;border:1px solid #ddd;border-radius:6px;padding:7px 10px;font-size:14px">' +
      '<span class="rm-unit" style="font-size:13px;color:#888;min-width:16px">' + (mode === 'ratio' ? '%' : '') + '</span>' +
    '</div>';
  }).join('');
}

function onRmModeChange(sel) {
  var row = sel.parentNode;
  var inp = row.querySelector('.rm-val');
  var unit = row.querySelector('.rm-unit');
  var mode = sel.value;
  inp.value = '';
  inp.placeholder = mode === 'ratio' ? '如：20（%）' : '如：income*0.2';
  unit.textContent = mode === 'ratio' ? '%' : '';
}

function clearRuleMembers() {
  document.querySelectorAll('#ruleMembersWrap .rm-row .rm-val').forEach(function(inp) { inp.value = ''; });
}

function collectRuleMembers() {
  var rows = document.querySelectorAll('#ruleMembersWrap .rm-row');
  var result = [];
  rows.forEach(function(row) {
    var name = row.getAttribute('data-name');
    var mode = row.querySelector('.rm-mode').value;
    var val = row.querySelector('.rm-val').value.trim();
    if (!val) return;
    if (mode === 'ratio') {
      var r = parseFloat(val);
      if (!isNaN(r) && r > 0) result.push({ member_name: name, rule_mode: 'ratio', ratio: r / 100 });
    } else {
      result.push({ member_name: name, rule_mode: 'formula', formula: val });
    }
  });
  return result;
}

function onRuleChange() {
  var type = document.getElementById('tRuleType').value;
  document.getElementById('leaderFields').style.display = (type === 'custom') ? 'none' : 'block';
  document.getElementById('reimburseRow').style.display = (type === 'zteam') ? 'block' : 'none';
  document.getElementById('customFields').style.display = (type === 'custom') ? 'block' : 'none';
  // 切换到自定义且行为空时，自动用已加载成员填充
  if (type === 'custom' && document.getElementById('allocationsWrap').children.length === 0 && currentFormMembers.length > 0) {
    currentFormMembers.forEach(function(m) { addAllocation(m.name, ''); });
  }
}

function addAllocation(name, ratio) {
  var wrap = document.getElementById('allocationsWrap');
  var row = document.createElement('div');
  row.style.cssText = 'display:flex;gap:8px;margin-bottom:8px;align-items:center';
  row.innerHTML =
    '<input type="text" placeholder="成员姓名" value="' + (name||'') + '" style="flex:2;border:1px solid #ddd;border-radius:6px;padding:7px 10px;font-size:14px;background:#f8f8f8" readonly>' +
    '<input type="number" placeholder="比例" min="0" max="100" step="1" value="' + (ratio||'') + '" style="flex:1;border:1px solid #ddd;border-radius:6px;padding:7px 10px;font-size:14px" oninput="updateRatioSum()">' +
    '<span style="font-size:13px;color:#888">%</span>' +
    '<button type="button" onclick="this.parentNode.remove();updateRatioSum()" style="background:none;border:none;color:#f44;cursor:pointer;font-size:16px">✕</button>';
  wrap.appendChild(row);
  updateRatioSum();
}

function addAllocationEditable(name, ratio) {
  var wrap = document.getElementById('allocationsWrap');
  var row = document.createElement('div');
  row.style.cssText = 'display:flex;gap:8px;margin-bottom:8px;align-items:center';
  row.innerHTML =
    '<input type="text" placeholder="成员姓名" value="' + (name||'') + '" style="flex:2;border:1px solid #ddd;border-radius:6px;padding:7px 10px;font-size:14px" oninput="updateRatioSum()">' +
    '<input type="number" placeholder="比例" min="0" max="100" step="1" value="' + (ratio||'') + '" style="flex:1;border:1px solid #ddd;border-radius:6px;padding:7px 10px;font-size:14px" oninput="updateRatioSum()">' +
    '<span style="font-size:13px;color:#888">%</span>' +
    '<button type="button" onclick="this.parentNode.remove();updateRatioSum()" style="background:none;border:none;color:#f44;cursor:pointer;font-size:16px">✕</button>';
  wrap.appendChild(row);
  updateRatioSum();
}


function updateRatioSum() {
  var inputs = document.querySelectorAll('#allocationsWrap input[type=number]');
  var sum = 0;
  inputs.forEach(function(inp){ sum += parseFloat(inp.value) || 0; });
  var el = document.getElementById('ratioSum');
  el.textContent = '当前合计：' + sum.toFixed(0) + '%' + (Math.abs(sum - 100) < 0.01 ? ' ✅' : ' （需调整至100%）');
  el.style.color = Math.abs(sum - 100) < 0.01 ? '#4caf50' : '#f44336';
}

async function showTeamForm(team) {
  document.getElementById('teamFormWrap').style.display = 'block';
  document.getElementById('formTitle').textContent = team ? '编辑团队' : '新建团队';
  document.getElementById('teamId').value = team ? team.id : '';
  document.getElementById('tName').value = team ? team.name : '';
  document.getElementById('tRuleType').value = team ? team.rule_type : 'zteam';
  document.getElementById('teamFormErr').style.display = 'none';
  document.getElementById('allocationsWrap').innerHTML = '';
  document.getElementById('leaderSuggestions').innerHTML = '';

  var cfg = (team && team.rule_config) ? team.rule_config : {};
  document.getElementById('tLeaderName').value = cfg.leader_name || '';
  document.getElementById('tLeaderRatio').value = cfg.leader_ratio != null ? (cfg.leader_ratio * 100).toFixed(0) : '20';
  document.getElementById('tReimburse').checked = cfg.reimburse_expenses !== false;

  // 加载该团队的所有成员（含admin）
  currentFormMembers = [];
  if (team && team.id) {
    var res = await api('/api/users?team_id=' + team.id);
    currentFormMembers = (res ? res.data || [] : []).filter(function(m){ return m.name; });
  }

  // 显示团队成员标签（可点击填充负责人姓名）
  var tagsEl = document.getElementById('memberTags');
  var tagListEl = document.getElementById('memberTagList');
  if (currentFormMembers.length > 0) {
    tagListEl.innerHTML = currentFormMembers.map(function(m, i) {
      return '<span onclick="pickLeader(' + i + ')" title="点击设为负责人" ' +
        'style="display:inline-block;background:#f0f0f0;border-radius:4px;padding:2px 8px;margin:2px 4px 2px 0;font-size:12px;cursor:pointer">' +
        m.name + '</span>';
    }).join('');
    tagsEl.style.display = 'block';
  } else {
    tagsEl.style.display = 'none';
  }

  // 负责人下拉建议
  document.getElementById('leaderSuggestions').innerHTML = currentFormMembers.map(function(m) {
    return '<option value="' + m.name + '">';
  }).join('');

  // 自定义规则：用成员列表预填行
  if (team && team.rule_type === 'custom') {
    var savedAllocs = cfg.allocations || [];
    var savedMap = {};
    savedAllocs.forEach(function(a){ savedMap[a.name] = (a.ratio * 100).toFixed(0); });

    if (currentFormMembers.length > 0) {
      // 有团队成员：用成员列表，已保存的比例回填，新成员空白
      currentFormMembers.forEach(function(m) {
        addAllocation(m.name, savedMap[m.name] || '');
      });
      // 已保存但不在成员列表中的也显示出来（可能已移出团队）
      savedAllocs.forEach(function(a) {
        var inMembers = currentFormMembers.some(function(m){ return m.name === a.name; });
        if (!inMembers) addAllocation(a.name, (a.ratio*100).toFixed(0));
      });
    } else if (savedAllocs.length > 0) {
      savedAllocs.forEach(function(a){ addAllocation(a.name, (a.ratio*100).toFixed(0)); });
    }
  }

  // 成员分账配置区段
  if (currentFormMembers.length > 0 || (team && team.rule_members && team.rule_members.length > 0)) {
    document.getElementById('ruleMembersSection').style.display = 'block';
    renderRuleMembers(currentFormMembers, team ? (team.rule_members || []) : []);
  } else {
    document.getElementById('ruleMembersSection').style.display = 'none';
  }

  onRuleChange();
  document.getElementById('teamFormWrap').scrollIntoView({ behavior: 'smooth' });
}

function hideTeamForm() { document.getElementById('teamFormWrap').style.display = 'none'; }
function editTeam(id) { showTeamForm(teams.find(function(t){ return t.id === id; })); }

function buildRuleConfig() {
  var type = document.getElementById('tRuleType').value;
  if (type === 'custom') {
    var rows = document.querySelectorAll('#allocationsWrap > div');
    var allocations = [];
    rows.forEach(function(row) {
      var inputs = row.querySelectorAll('input');
      var name = inputs[0].value.trim();
      var ratio = parseFloat(inputs[1].value) / 100;
      if (name && !isNaN(ratio) && ratio > 0) allocations.push({ name: name, ratio: ratio });
    });
    return { allocations: allocations };
  }
  var cfg = {
    leader_name:  document.getElementById('tLeaderName').value.trim(),
    leader_ratio: parseFloat(document.getElementById('tLeaderRatio').value) / 100 || 0.2,
  };
  if (type === 'zteam') cfg.reimburse_expenses = document.getElementById('tReimburse').checked;
  return cfg;
}

document.getElementById('teamForm').addEventListener('submit', async function(e) {
  e.preventDefault();
  var id = document.getElementById('teamId').value;
  var cfg = buildRuleConfig();
  var ruleType = document.getElementById('tRuleType').value;
  var err = document.getElementById('teamFormErr');
  err.style.display = 'none';

  if (ruleType === 'custom') {
    var sum = (cfg.allocations||[]).reduce(function(s,a){ return s + a.ratio; }, 0);
    if (Math.abs(sum - 1) > 0.01) {
      err.textContent = '各成员比例之和须为100%，当前：' + (sum*100).toFixed(0) + '%';
      err.style.display = 'block';
      return;
    }
  }

  var body = {
    name: document.getElementById('tName').value,
    rule_type: ruleType,
    rule_config: cfg,
    rule_members: collectRuleMembers(),
  };
  var res = await api(id ? '/api/teams/'+id : '/api/teams', {
    method: id ? 'PUT' : 'POST', body: JSON.stringify(body)
  });
  if (res && res.ok) { hideTeamForm(); loadTeams(); }
  else { err.textContent = (res&&res.message)||'保存失败'; err.style.display='block'; }
});

loadTeams();
</script>`;
%>
<%- include('layout', { title, page, body, pageScript }) %>
