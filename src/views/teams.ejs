<%
const title = '团队管理';
const page  = 'teams';
const body = `
<div class="page-header">
  <h2>团队管理</h2>
  <button class="btn btn-primary" onclick="showTeamForm()">+ 新建团队</button>
</div>

<div id="teamFormWrap" style="display:none" class="card form-card">
  <h3 id="formTitle">新建团队</h3>
  <form id="teamForm">
    <input type="hidden" id="teamId">
    <div class="form-row">
      <label>团队名称 *</label>
      <input type="text" id="tName" required placeholder="如：性价屋Z团队">
    </div>

    <div style="border:1px solid #c8d8ff;border-radius:8px;padding:14px;margin-top:12px;background:#f8f9ff">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px">
        <span style="font-size:14px;font-weight:600;color:#333">成员分账配置</span>
        <button type="button" class="btn btn-sm" onclick="clearRuleMembers()">清空</button>
      </div>
      <div id="memberTags" style="display:none;margin-bottom:10px;font-size:13px;color:#555">
        <span style="color:#888">团队成员：</span>
        <span id="memberTagList"></span>
      </div>
      <div style="background:#eef2ff;border-radius:6px;padding:8px 12px;margin-bottom:12px;font-size:12px;color:#555;line-height:2">
        <span style="color:#888;margin-right:6px">公式可用变量（点击复制）：</span>
        <span onclick="copyVar('income')"        style="display:inline-block;background:#fff;border:1px solid #c0c8f0;border-radius:4px;padding:1px 7px;margin:2px 3px;cursor:pointer;color:#4a5aef;font-family:monospace">income</span><span style="color:#aaa;font-size:11px">总收入</span>
        <span onclick="copyVar('tax')"           style="display:inline-block;background:#fff;border:1px solid #c0c8f0;border-radius:4px;padding:1px 7px;margin:2px 3px;cursor:pointer;color:#4a5aef;font-family:monospace">tax</span><span style="color:#aaa;font-size:11px">税额</span>
        <span onclick="copyVar('expense')"       style="display:inline-block;background:#fff;border:1px solid #c0c8f0;border-radius:4px;padding:1px 7px;margin:2px 3px;cursor:pointer;color:#4a5aef;font-family:monospace">expense</span><span style="color:#aaa;font-size:11px">支出</span>
        <span onclick="copyVar('adjust')"        style="display:inline-block;background:#fff;border:1px solid #c0c8f0;border-radius:4px;padding:1px 7px;margin:2px 3px;cursor:pointer;color:#4a5aef;font-family:monospace">adjust</span><span style="color:#aaa;font-size:11px">调整</span>
        <span onclick="copyVar('distributable')" style="display:inline-block;background:#fff;border:1px solid #c0c8f0;border-radius:4px;padding:1px 7px;margin:2px 3px;cursor:pointer;color:#4a5aef;font-family:monospace">distributable</span><span style="color:#aaa;font-size:11px">可分配=收入-税-支出+调整</span>
        <span id="copyHint" style="color:#4caf50;margin-left:6px;display:none">已复制</span>
      </div>
      <div id="ruleMembersWrap"></div>
    </div>

    <div style="border:1px solid #e0e0e0;border-radius:8px;padding:14px;margin-top:12px;background:#fafafa">
      <div style="font-size:14px;font-weight:600;color:#333;margin-bottom:10px">⚙️ 企业微信自动化</div>
      <div class="form-row">
        <label>企业微信 Webhook URL</label>
        <input type="text" id="tWecomWebhook" placeholder="https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=...">
      </div>
      <div style="display:flex;gap:24px;margin-top:10px">
        <label style="display:flex;align-items:center;gap:6px;font-size:14px;cursor:pointer">
          <input type="checkbox" id="tAutoSettle"> 全员提交后自动结算
        </label>
        <label style="display:flex;align-items:center;gap:6px;font-size:14px;cursor:pointer">
          <input type="checkbox" id="tAutoPush"> 结算完自动推送企业微信
        </label>
      </div>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn btn-primary">保存</button>
      <button type="button" class="btn" onclick="hideTeamForm()">取消</button>
    </div>
    <div id="teamFormErr" class="error-msg" style="display:none"></div>
  </form>
</div>

<div class="table-wrap">
  <table class="data-table">
    <thead><tr><th>ID</th><th>团队名称</th><th>成员分账配置</th><th>状态</th><th>操作</th></tr></thead>
    <tbody id="teamListBody"><tr><td colspan="5">加载中...</td></tr></tbody>
  </table>
</div>

<div id="confirmMask" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:9999;align-items:center;justify-content:center">
  <div style="background:#fff;border-radius:10px;padding:28px 32px;max-width:340px;width:90%;box-shadow:0 8px 32px rgba(0,0,0,.18)">
    <div id="confirmMsg" style="font-size:15px;margin-bottom:20px;line-height:1.5"></div>
    <div style="display:flex;justify-content:flex-end;gap:10px">
      <button id="confirmCancel" class="btn">取消</button>
      <button id="confirmOk" class="btn btn-primary" style="background:#f44336;border-color:#f44336">确认删除</button>
    </div>
  </div>
</div>
`;
const pageScript = `<script>
let teams = [];
let currentFormMembers = [];

function describeRule(t) {
  var rm = t.rule_members || [];
  if (rm.length > 0) {
    return rm.map(function(m) {
      if (m.rule_mode === 'formula') return m.member_name + '：' + (m.formula || '-');
      return m.member_name + '：' + (m.ratio != null ? (m.ratio * 100).toFixed(0) + '%' : '-');
    }).join('　');
  }
  return '<span style="color:#aaa">未配置</span>';
}

async function loadTeams() {
  const res = await api('/api/teams');
  if (!res) return;
  teams = res.data || [];
  document.getElementById('teamListBody').innerHTML = teams.map(function(t) {
    return '<tr>' +
      '<td>' + t.id + '</td>' +
      '<td><strong>' + t.name + '</strong></td>' +
      '<td style="font-size:13px">' + describeRule(t) + '</td>' +
      '<td>' + (t.status ? '✅启用' : '🚫停用') + '</td>' +
      '<td>' +
        '<button class="btn btn-sm" onclick="editTeam(' + t.id + ')">编辑</button> ' +
        '<button class="btn btn-sm" style="color:#f44;border-color:#f44" onclick="deleteTeam(' + t.id + ')">删除</button>' +
      '</td>' +
      '</tr>';
  }).join('') || '<tr><td colspan="5">暂无团队</td></tr>';
}

function copyVar(v) {
  navigator.clipboard.writeText(v).catch(function() {
    var ta = document.createElement('textarea');
    ta.value = v; document.body.appendChild(ta); ta.select(); document.execCommand('copy'); document.body.removeChild(ta);
  });
  var hint = document.getElementById('copyHint');
  hint.textContent = '已复制 ' + v;
  hint.style.display = 'inline';
  clearTimeout(copyVar._t);
  copyVar._t = setTimeout(function() { hint.style.display = 'none'; }, 1500);
}

function renderRuleMembers(members, savedRuleMembers) {
  var wrap = document.getElementById('ruleMembersWrap');
  if (members.length === 0) {
    wrap.innerHTML = '<div style="color:#aaa;font-size:13px">请先在成员管理中为该团队分配成员</div>';
    return;
  }
  var ruleMap = {};
  (savedRuleMembers || []).forEach(function(r) { ruleMap[r.member_name] = r; });
  wrap.innerHTML = members.map(function(m) {
    var rm = ruleMap[m.name] || {};
    var mode = rm.rule_mode || 'formula';
    var val = mode === 'formula' ? (rm.formula || '') : (rm.ratio != null ? (rm.ratio * 100).toFixed(0) : '');
    return '<div class="rm-row" data-name="' + m.name + '" style="display:flex;gap:8px;margin-bottom:8px;align-items:center">' +
      '<span style="flex:2;font-size:14px">' + m.name + '</span>' +
      '<select class="rm-mode" onchange="onRmModeChange(this)" style="flex:1;border:1px solid #ddd;border-radius:6px;padding:7px 8px;font-size:13px">' +
        '<option value="formula"' + (mode === 'formula' ? ' selected' : '') + '>公式</option>' +
        '<option value="ratio"'   + (mode === 'ratio'   ? ' selected' : '') + '>固定比例</option>' +
      '</select>' +
      '<input class="rm-val" type="text" value="' + val + '" ' +
        'placeholder="' + (mode === 'ratio' ? '如：20（%）' : '如：income*0.2') + '" ' +
        'style="flex:3;border:1px solid #ddd;border-radius:6px;padding:7px 10px;font-size:14px">' +
      '<span class="rm-unit" style="font-size:13px;color:#888;min-width:16px">' + (mode === 'ratio' ? '%' : '') + '</span>' +
    '</div>';
  }).join('');
}

function onRmModeChange(sel) {
  var row = sel.parentNode;
  var inp = row.querySelector('.rm-val');
  var unit = row.querySelector('.rm-unit');
  var mode = sel.value;
  inp.value = '';
  inp.placeholder = mode === 'ratio' ? '如：20（%）' : '如：income*0.2';
  unit.textContent = mode === 'ratio' ? '%' : '';
}

function clearRuleMembers() {
  document.querySelectorAll('#ruleMembersWrap .rm-row .rm-val').forEach(function(inp) { inp.value = ''; });
}

function collectRuleMembers() {
  var rows = document.querySelectorAll('#ruleMembersWrap .rm-row');
  var result = [];
  rows.forEach(function(row) {
    var name = row.getAttribute('data-name');
    var mode = row.querySelector('.rm-mode').value;
    var val = row.querySelector('.rm-val').value.trim();
    if (!val) return;
    if (mode === 'ratio') {
      var r = parseFloat(val);
      if (!isNaN(r) && r > 0) result.push({ member_name: name, rule_mode: 'ratio', ratio: r / 100 });
    } else {
      result.push({ member_name: name, rule_mode: 'formula', formula: val });
    }
  });
  return result;
}

async function showTeamForm(team) {
  document.getElementById('teamFormWrap').style.display = 'block';
  document.getElementById('formTitle').textContent = team ? '编辑团队' : '新建团队';
  document.getElementById('teamId').value = team ? team.id : '';
  document.getElementById('tName').value = team ? team.name : '';
  document.getElementById('tWecomWebhook').value = team ? (team.wecom_webhook_url || '') : '';
  document.getElementById('tAutoSettle').checked = team ? !!team.auto_settle_enabled : false;
  document.getElementById('tAutoPush').checked = team ? !!team.auto_push_enabled : false;
  document.getElementById('teamFormErr').style.display = 'none';

  currentFormMembers = [];
  if (team && team.id) {
    var res = await api('/api/users?team_id=' + team.id);
    currentFormMembers = (res ? res.data || [] : []).filter(function(m){ return m.name; });
  }

  var tagsEl = document.getElementById('memberTags');
  var tagListEl = document.getElementById('memberTagList');
  if (currentFormMembers.length > 0) {
    tagListEl.innerHTML = currentFormMembers.map(function(m) {
      return '<span style="display:inline-block;background:#f0f0f0;border-radius:4px;padding:2px 8px;margin:2px 4px 2px 0;font-size:12px">' + m.name + '</span>';
    }).join('');
    tagsEl.style.display = 'block';
  } else {
    tagsEl.style.display = 'none';
  }

  renderRuleMembers(currentFormMembers, team ? (team.rule_members || []) : []);
  document.getElementById('teamFormWrap').scrollIntoView({ behavior: 'smooth' });
}

function hideTeamForm() { document.getElementById('teamFormWrap').style.display = 'none'; }
function editTeam(id) { showTeamForm(teams.find(function(t){ return t.id === id; })); }

document.getElementById('teamForm').addEventListener('submit', async function(e) {
  e.preventDefault();
  var id = document.getElementById('teamId').value;
  var err = document.getElementById('teamFormErr');
  err.style.display = 'none';
  var body = {
    name:               document.getElementById('tName').value,
    rule_type:          'custom',
    rule_config:        { allocations: [] },
    rule_members:       collectRuleMembers(),
    wecom_webhook_url:  document.getElementById('tWecomWebhook').value.trim() || null,
    auto_settle_enabled: document.getElementById('tAutoSettle').checked ? 1 : 0,
    auto_push_enabled:   document.getElementById('tAutoPush').checked   ? 1 : 0,
  };
  var res = await api(id ? '/api/teams/'+id : '/api/teams', {
    method: id ? 'PUT' : 'POST', body: JSON.stringify(body)
  });
  if (res && res.ok) { hideTeamForm(); loadTeams(); }
  else { err.textContent = (res&&res.message)||'保存失败'; err.style.display='block'; }
});

function deleteTeam(id) {
  var team = teams.find(function(t){ return t.id === id; });
  var name = team ? team.name : '该团队';
  var mask = document.getElementById('confirmMask');
  document.getElementById('confirmMsg').textContent = '确认删除团队「' + name + '」？此操作不可恢复。';
  mask.style.display = 'flex';
  document.getElementById('confirmOk').onclick = async function() {
    mask.style.display = 'none';
    var res = await api('/api/teams/' + id, { method: 'DELETE' });
    if (res && res.ok) loadTeams();
  };
  document.getElementById('confirmCancel').onclick = function() { mask.style.display = 'none'; };
}

loadTeams();
</script>`;
%>
<%- include('layout', { title, page, body, pageScript }) %>
