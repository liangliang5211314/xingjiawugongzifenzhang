# 服务器
PORT=3000
JWT_SECRET=请替换为长随机字符串

# 管理员账号（首次init.js时创建）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=请设置强密码

# 数据库路径（绝对路径，确保目录存在）
DB_PATH=./data/app.db

# 系统对外域名（用于微信回调、推送详情链接）
BASE_URL=https://your-domain.com

# 微信公众号（服务号，需网页授权+模板消息权限）
WX_APPID=
WX_SECRET=
WX_REDIRECT_URI=https://your-domain.com/auth/wechat/callback
WX_TEMPLATE_ID=

# 飞书开放平台（企业自建应用）
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_SPREADSHEET_TOKEN=
FEISHU_RECORDS_SHEET_ID=
FEISHU_SETTLEMENTS_SHEET_ID=
